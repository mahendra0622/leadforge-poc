# Database (set automatically by Render, or manually for local dev)
DATABASE_URL=postgresql://fintellipro:fintellipro_dev@localhost:5432/fintellipro

# Redis
REDIS_URL=redis://localhost:6379/0

# Security — generate a strong random string for production
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Anthropic (Claude AI)
ANTHROPIC_API_KEY=

# Google OAuth (Gmail integration)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/gmail/callback

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# App
APP_ENV=development
LOG_LEVEL=INFO
